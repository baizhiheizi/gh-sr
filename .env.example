# Fine-grained PAT with "Administration" write permission on target repos
# Create at: https://github.com/settings/personal-access-tokens/new
# Required permissions: Administration (write) on each repo listed in config/runners.yml
GITHUB_PAT=github_pat_REPLACE_ME

# Runner version to install in the Docker image.
# Use "latest" to always build with the newest release, or pin to a specific
# version (e.g. 2.333.1) for reproducible builds.
RUNNER_VERSION=latest
